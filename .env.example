# =============================================================================
# Environment: Intel Arc Graphics (Meteor Lake-P, integrated/UMA)
# =============================================================================
# GPU:  Intel Arc Graphics (Meteor Lake-P iGPU) — Xe-LPG architecture
# VRAM: No dedicated VRAM. UMA (Unified Memory Architecture) — GPU and CPU
#       share the same 64 GB system RAM. "VRAM" is a soft allocation of RAM.
# CPU:  22 logical cores
# RAM:  64 GB total
# OS:   Fedora Linux (kernel 6.19), container runtime: Podman
# Backend: SYCL via Intel oneAPI / Level Zero (libggml-sycl.so, icpx-compiled)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Ollama server & runtime behavior
# ─────────────────────────────────────────────────────────────────────────────

# Only one request served at a time. UMA iGPUs are memory-bandwidth-limited;
# parallelism would throttle all requests equally with no throughput gain.
OLLAMA_NUM_PARALLEL=1

# Keep models resident in "VRAM" (shared RAM) for 2h to avoid reload latency.
OLLAMA_KEEP_ALIVE=2h

# Only one model loaded at a time. No dedicated VRAM to spare for multiple
# resident models; swapping would be slow anyway.
OLLAMA_MAX_LOADED_MODELS=1

OLLAMA_MAX_QUEUE=512
OLLAMA_DEBUG=0

# ─────────────────────────────────────────────────────────────────────────────
# Context length & attention
# ─────────────────────────────────────────────────────────────────────────────

# 8192 tokens is a practical balance: enough context for most tasks without
# excessive KV-cache memory consumption. Each token in the KV cache consumes
# GPU memory; larger contexts reduce the model size that can fully fit.
OLLAMA_CONTEXT_LENGTH=8192

# Flash attention works correctly on both SYCL and Vulkan paths with this iGPU.
OLLAMA_FLASH_ATTENTION=true

# q4_0 KV cache: requires flash_attn=true (enforced by llama.cpp). Uses 3.5x less
# memory than f16 at the same context length, freeing budget for larger models.
OLLAMA_KV_CACHE_TYPE=q4_0
OLLAMA_GPU_OVERHEAD=268435456   # 256 MiB — reserves display/overhead memory

# ─────────────────────────────────────────────────────────────────────────────
# GPU layer offloading
# ─────────────────────────────────────────────────────────────────────────────

# Offload all transformer layers to GPU. With UMA the "GPU memory" is the same
# physical RAM, so full offload is always preferred — CPU inference is slower.
OLLAMA_NUM_GPU=999

# ─────────────────────────────────────────────────────────────────────────────
# Allow usage of iGPU
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_IGPU_ENABLE=1

# ─────────────────────────────────────────────────────────────────────────────
# SYCL / Level Zero performance tuning
# ─────────────────────────────────────────────────────────────────────────────

# Enable fp16 math in the ggml-sycl backend. Intel's compute-runtime handles
# fp16 correctly on Arc via Level Zero. Works correctly with flash attention on.
GGML_SYCL_F16=1

# Disable SYCL debug output. Referenced in docker-compose so set explicitly
# to 0 to suppress any accidental debug logging in production.
GGML_SYCL_DEBUG=0
